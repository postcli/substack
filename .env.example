# Credentials are stored at ~/.config/postcli/.env
# Run `postcli-substack auth login` to configure automatically.
#
# Manual setup: open Substack in Chrome > DevTools > Application > Cookies
# Copy `substack.sid` and `connect.sid` values, then generate the token:
#   node -e "console.log(Buffer.from(JSON.stringify({ substack_sid: 'YOUR_SID', connect_sid: 'YOUR_SID' })).toString('base64'))"
#
SUBSTACK_TOKEN=your_base64_token_here
SUBSTACK_PUBLICATION_URL=https://yourpublication.substack.com
